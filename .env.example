# NextAuth / Auth.js configuration
# Generate a secret using: npx auth secret
AUTH_SECRET=

# Spotify Developer Dashboard (https://developer.spotify.com/dashboard)
# Note: Set Redirect URI to http://127.0.0.1:3000/api/auth/callback/spotify
AUTH_SPOTIFY_ID=
AUTH_SPOTIFY_SECRET=

# Supabase configuration (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: Supabase Service Role Key (Server-side only)
# SUPABASE_SERVICE_ROLE_KEY=
